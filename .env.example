# Version 1.1 requires NO environment variables. The site builds and runs with
# this file absent. Everything below is FUTURE PREPARATION — see docs/roadmap.md.
#
# Copy to .env.local only when you actually implement one of these.

# --- Site ---------------------------------------------------------------
# Optional. Falls back to SITE.url in data/site.ts, which you should set to the
# real domain before launch — sitemap, canonical URLs and social previews use it.
# NEXT_PUBLIC_SITE_URL=https://shazoniquesinspirations.com

# --- Supabase (not implemented) -----------------------------------------
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=      # server only — never expose to the browser

# --- Email Reflections (not implemented) --------------------------------
# RESEND_API_KEY=
# REFLECTION_EMAIL_FROM=reflections@shazoniquesinspirations.com
# CRON_SECRET=                    # guards the scheduled send route
